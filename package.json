{
  "name": "unidb",
  "version": "0.1.0",
  "description": "Modern cross-platform database management tool",
  "main": "dist-electron/main.js",
  "author": "UniDb Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "postinstall": "node node_modules/electron/install.js && electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.2",
    "@vicons/ionicons5": "^0.12.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "ioredis": "^5.10.1",
    "mongodb": "^7.1.1",
    "mysql2": "^3.20.0",
    "naive-ui": "^2.44.1",
    "node-sql-parser": "^5.4.0",
    "pinia": "^3.0.4",
    "sql-formatter": "^15.7.3",
    "uuid": "^11.0.5",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  }
}
